#!/usr/bin/env bash

entries="’ĆŻ Lock\n’ŗĄ Logout\n’Ć× Reboot\n’Ćæ Shutdown\n’åå Suspend"

selected=$(echo -e "$entries" | rofi -dmenu -p "Power" -theme-str 'window {width: 200px;} listview {lines: 5;}')

case "$selected" in
    *Lock)
        if command -v i3lock &>/dev/null; then
            i3lock -c 2d353b
        else
            xflock4
        fi
        ;;
    *Logout)
        xfce4-session-logout --logout
        ;;
    *Reboot)
        systemctl reboot
        ;;
    *Shutdown)
        systemctl poweroff
        ;;
    *Suspend)
        systemctl suspend
        ;;
esac
