#!/bin/bash
xfce4-terminal --hold -e "bash -c '
echo \"       KEYBOARD SHORTCUTS\"
echo \"──────────────────────────────────────────\"
echo \"\"
echo \"-- Window Management --\"
echo \"  Super+Q          Close window\"
echo \"  Super+Tab        Switch window\"
echo \"  Alt+Tab          Cycle windows\"
echo \"  Alt+F4           Close window\"
echo \"  Alt+F7           Move window\"
echo \"  Alt+F8           Resize window\"
echo \"  Alt+F10          Maximize\"
echo \"  Alt+F11          Fullscreen\"
echo \"  Ctrl+Alt+D       Show desktop\"
echo \"\"
echo \"-- Applications --\"
echo \"  Super+Return     Terminal\"
echo \"  Super+Space      App launcher (rofi)\"
echo \"  Super+Shift+F    File manager\"
echo \"  Super+Shift+N    Neovim\"
echo \"  Super+Shift+R    Ranger (file browser)\"
echo \"  Super+Shift+B    Browser\"
echo \"  Super+Alt+Return Tmux terminal\"
echo \"  Super+H          Home directory\"
echo \"  Super+L          Lock screen\"
echo \"\"
echo \"-- Screenshots --\"
echo \"  Print            Select region\"
echo \"  Super+Print      Full screen\"
echo \"  Ctrl+Print       Active window\"
echo \"  Shift+Print      Region to clipboard\"
echo \"\"
echo \"-- Workspaces --\"
echo \"  Ctrl+Alt+Left    Previous workspace\"
echo \"  Ctrl+Alt+Right   Next workspace\"
echo \"  Ctrl+Alt+Up/Down Switch workspace\"
echo \"  Ctrl+F1-F6       Go to workspace 1-6\"
echo \"\"
echo \"-- System --\"
echo \"  Super+F1         This help\"
echo \"  Super+X          Power menu\"
echo \"  Ctrl+Alt+Delete  Logout\"
echo \"  Super+P          Display settings\"
echo \"\"
echo \"Press Ctrl+C to close\""' 2>/dev/null
