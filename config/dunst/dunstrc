[global]
    monitor = 0
    follow = mouse
    width = 350
    height = (0, 200)
    offset = 16x48
    origin = top-right
    notification_limit = 5
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    indicate_hidden = yes
    transparency = 10
    separator_height = 2
    padding = 16
    horizontal_padding = 16
    text_icon_padding = 8
    frame_width = 2
    frame_color = "#7fbbb3"
    corner_radius = 8
    gap_size = 8
    sort = yes
    font = "JetBrains Mono 10"
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = top
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    sticky_history = yes
    history_length = 20
    dmenu = rofi -dmenu -p dunst
    browser = chromium
    always_run_script = true
    title = Dunst
    class = Dunst
    startup_notification = false
    force_xinerama = false

[shortcuts]
    close = mod4+grave
    close_all = mod4+shift+grave
    history = mod4+period
    context = mod4+apostrophe

[urgency_low]
    background = "#2d353b"
    foreground = "#d3c6aa"
    timeout = 5
    highlight = "#7fbbb3"

[urgency_normal]
    background = "#2d353b"
    foreground = "#d3c6aa"
    timeout = 8
    highlight = "#a7c080"

[urgency_critical]
    background = "#2d353b"
    foreground = "#e67e80"
    timeout = 0
    highlight = "#e67e80"
